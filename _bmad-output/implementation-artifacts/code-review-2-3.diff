+    out["os_client_sec"] = snapshot.network.opensky_client_secret;
+    out["aeroapi_key"] = snapshot.network.aeroapi_key;
+}
+
+void ConfigManager::persistAllNow() {
+    persistToNvs();
+    _persistPending = false;
+    _persistScheduledAt = 0;
