+// --- onChange Callback ---
+
+void test_on_change_callback_fires() {
+    clearNvs();
+    ConfigManager::init();
+
+    bool callbackFired = false;
+    ConfigManager::onChange([&callbackFired]() {
+        callbackFired = true;
+    });
+
+    JsonDocument doc;
+    doc["brightness"] = 77;
+    JsonObject settings = doc.as<JsonObject>();
+    ConfigManager::applyJson(settings);
+
+    TEST_ASSERT_TRUE(callbackFired);
+}
