+/* FlightWall System Health — minimal status page (Story 2.4 will expand) */
+(function() {
+  'use strict';
+
+  var healthList = document.getElementById('health-list');
+  var healthLoading = document.getElementById('health-loading');
+
+  function levelColor(level) {
+    if (level === 'ok') return 'var(--success)';
+    if (level === 'warning') return '#d29922';
+    return 'var(--error)';
+  }
+
+  FW.get('/api/status').then(function(res) {
+    healthLoading.style.display = 'none';
+    if (!res.body.ok || !res.body.data) {
+      FW.showToast('Failed to load status', 'error');
+      return;
+    }
+    var data = res.body.data;
+    var html = '';
+    var keys = Object.keys(data);
+    keys.forEach(function(name) {
+      var s = data[name];
+      html += '<div style="display:flex;justify-content:space-between;align-items:baseline;padding:6px 0;border-bottom:1px solid var(--border)">';
+      html += '<span style="font-size:0.875rem;text-transform:capitalize">' + name + '</span>';
+      html += '<span style="font-size:0.8125rem;color:' + levelColor(s.level) + '">' + s.level.toUpperCase() + '</span>';
+      html += '</div>';
+    });
+    healthList.innerHTML = html;
+  }).catch(function() {
+    healthLoading.textContent = 'Cannot reach device';
+    healthLoading.style.color = 'var(--error)';
+  });
+})();
diff --git a/Users/christianlee/App-Development/TheFlightWall_OSS-main/firmware/data-src/common.js b/Users/christianlee/App-Development/TheFlightWall_OSS-main/firmware/data-src/common.js
