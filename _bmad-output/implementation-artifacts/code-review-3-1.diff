+  var mode;
+  if (mh < 32) { mode = 'compact'; }
+  else if (mh < 48) { mode = 'full'; }
+  else { mode = 'expanded'; }
+
+  var halfH = Math.floor(mh / 2);
+
+  return {
+    matrixWidth: mw,
+    matrixHeight: mh,
+    mode: mode,
+    logoZone:      { x: 0,  y: 0,     w: mh,      h: mh },
+    flightZone:    { x: mh, y: 0,     w: mw - mh, h: halfH },
+    telemetryZone: { x: mh, y: halfH, w: mw - mh, h: mh - halfH },
+    valid: true
+  };
+}
