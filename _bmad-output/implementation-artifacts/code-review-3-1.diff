+    LayoutResult r = LayoutEngine::compute(1, 10, 16);
+    TEST_ASSERT_FALSE(r.valid);
+    TEST_ASSERT_EQUAL_UINT16(16, r.matrixWidth);
+    TEST_ASSERT_EQUAL_UINT16(160, r.matrixHeight);
+}
