+++ b/firmware/src/main.cpp
@@ -0,0 +1,255 @@
+/*
+Purpose: Firmware entry point for ESP32.
+Responsibilities:
+- Initialize serial, connect to Wi-Fi, and construct fetchers and display.
+- Periodically fetch state vectors (OpenSky), enrich flights (AeroAPI), and push to queue.
+- Display task on Core 0 reads queue and renders to LED matrix independently.
+Configuration: ConfigManager (NVS-backed with compile-time fallbacks).
+Architecture: Producer-Consumer dual-core (Core 1 = fetch/network, Core 0 = display).
+*/
+#include <vector>
+#include <atomic>
+#include <WiFi.h>
+#include <HTTPClient.h>
+#include <WiFiClientSecure.h>
+#include <LittleFS.h>
+#include <freertos/FreeRTOS.h>
+#include <freertos/task.h>
+#include <freertos/queue.h>
+#include "esp_task_wdt.h"
+#include "utils/Log.h"
+#include "core/ConfigManager.h"
+#include "core/SystemStatus.h"
+#include "adapters/OpenSkyFetcher.h"
+#include "adapters/AeroAPIFetcher.h"
+#include "core/FlightDataFetcher.h"
+#include "adapters/NeoMatrixDisplay.h"
+#include "adapters/WiFiManager.h"
+
+#ifndef PIO_UNIT_TESTING
+
+// --- Shared data structures (Task 1) ---
+
+struct FlightDisplayData {
+    std::vector<FlightInfo> flights;
+};
+
+// Double buffer for safe cross-core data transfer (no memcpy of String/vector)
+static FlightDisplayData g_flightBuf[2];
+static uint8_t g_writeBuf = 0;
+
+// FreeRTOS queue holding a pointer to the current read buffer
+static QueueHandle_t g_flightQueue = nullptr;
+
+// Atomic flag for config change notification (Core 1 sets, Core 0 reads)
+static std::atomic<bool> g_configChanged(false);
+
+// --- Existing globals ---
+
+static OpenSkyFetcher g_openSky;
+static AeroAPIFetcher g_aeroApi;
+static FlightDataFetcher *g_fetcher = nullptr;
+static NeoMatrixDisplay g_display;
+static WiFiManager g_wifiManager;
+
+static unsigned long g_lastFetchMs = 0;
+
+// --- Display task (Task 2) ---
+
+void displayTask(void *pvParameters)
+{
+    LOG_I("DisplayTask", "Display task started");
+
+    // Read initial config as local copies
+    DisplayConfig localDisp = ConfigManager::getDisplay();
+    TimingConfig localTiming = ConfigManager::getTiming();
+
+    // Flight cycling state (owned by display task)
+    size_t currentFlightIndex = 0;
+    unsigned long lastCycleMs = millis();
+
+    // Subscribe to task watchdog
+    esp_task_wdt_add(NULL);
+
+    for (;;)
+    {
+        // AC3: Check config change atomic flag each frame
+        if (g_configChanged.exchange(false))
+        {
+            LOG_I("DisplayTask", "Config change detected");
+            localDisp = ConfigManager::getDisplay();
+            localTiming = ConfigManager::getTiming();
+
+            // Apply brightness update immediately
+            g_display.updateBrightness(localDisp.brightness);
+        }
+
+        // AC2: Peek latest flight data without removing from queue
+        FlightDisplayData *displayData = nullptr;
+        if (xQueuePeek(g_flightQueue, &displayData, 0) == pdTRUE && displayData != nullptr)
+        {
+            const std::vector<FlightInfo> &flights = displayData->flights;
+
+            if (!flights.empty())
+            {
+                // Flight cycling logic owned by display task
+                const unsigned long now = millis();
+                const unsigned long cycleMs = localTiming.display_cycle * 1000UL;
+
+                if (flights.size() > 1 && now - lastCycleMs >= cycleMs)
+                {
+                    lastCycleMs = now;
+                    currentFlightIndex = (currentFlightIndex + 1) % flights.size();
+                }
+                else if (flights.size() == 1)
+                {
+                    currentFlightIndex = 0;
+                }
+
+                // Render single flight (display task owns rendering)
+                g_display.renderFlight(flights[currentFlightIndex]);
+            }
+            else
+            {
+                g_display.showLoading();
+            }
+        }
+        else
+        {
+            // No data yet — show loading screen
+            g_display.showLoading();
+        }
+
+#if LOG_LEVEL >= 3
+        static unsigned long lastStackLogMs = 0;
+        if (millis() - lastStackLogMs > 30000)  // log every 30s
+        {
+            lastStackLogMs = millis();
+            Serial.print("[DisplayTask] Stack high watermark: ");
+            Serial.println(uxTaskGetStackHighWaterMark(NULL));
+        }
+#endif
+
+        // Reset watchdog and yield (~20fps)
+        esp_task_wdt_reset();
+        vTaskDelay(pdMS_TO_TICKS(50));
+    }
+}
+
+void setup()
+{
+    Serial.begin(115200);
+    delay(200);
+
+    if (!LittleFS.begin(true)) {
+        LOG_E("Main", "LittleFS mount failed");
+    } else {
+        LOG_I("Main", "LittleFS mounted");
+    }
+
+    ConfigManager::init();
+    SystemStatus::init();
+
+    // Register config change callback — Core 1 sets atomic, Core 0 reads it
+    ConfigManager::onChange([]() {
+        g_configChanged = true;
+    });
+
+    // Initialize queue (mailbox semantics: 1 slot, latest data wins)
+    g_flightQueue = xQueueCreate(1, sizeof(FlightDisplayData*));
+    if (g_flightQueue == nullptr)
+    {
+        LOG_E("Main", "Failed to create flight queue");
+    }
+    else
+    {
+        LOG_I("Main", "Flight queue created");
+    }
+
+    // Display init happens before task creation
+    g_display.initialize();
+    g_display.showLoading();
+
+    // Create display task on Core 0
+    BaseType_t taskOk = xTaskCreatePinnedToCore(
+        displayTask,
+        "display",
+        8192,      // 8KB stack (bytes on ESP32)
+        NULL,
+        1,         // priority 1
+        NULL,
+        0          // Core 0
+    );
+    if (taskOk != pdPASS)
+    {
+        LOG_E("Main", "Failed to create display task");
+    }
+    else
+    {
+        LOG_I("Main", "Display task created on Core 0");
+    }
+
+    // WiFi setup remains in setup() — WiFiManager is now story 1.4
+    bool wifiOk = g_wifiManager.connect();
+    if (!wifiOk)
+    {
+        LOG_E("Main", "WiFi connection failed");
+        g_display.displayMessage(String("WiFi FAIL"));
+    }
+
+    g_fetcher = new FlightDataFetcher(&g_openSky, &g_aeroApi);
+}
+
+void loop()
+{
+    // AC1: loop() stays on Core 1 and continues ConfigManager::tick()
+    ConfigManager::tick();
+
+    const unsigned long intervalMs = ConfigManager::getTiming().fetch_interval * 1000UL;
+    const unsigned long now = millis();
+    if (now - g_lastFetchMs >= intervalMs)
+    {
+        g_lastFetchMs = now;
+
+        std::vector<StateVector> states;
+        std::vector<FlightInfo> flights;
+        size_t enriched = g_fetcher->fetchFlights(states, flights);
+
+        LOG_I("Main", "Flight fetch cycle complete");
+#if LOG_LEVEL >= 3
+        Serial.print("[Main] OpenSky state vectors: ");
+        Serial.println((int)states.size());
+        Serial.print("[Main] AeroAPI enriched flights: ");
+        Serial.println((int)enriched);
+#endif
+
+        // AC2: Pack results into double buffer and overwrite queue with pointer
+        g_flightBuf[g_writeBuf].flights = flights;
+        FlightDisplayData *ptr = &g_flightBuf[g_writeBuf];
+        xQueueOverwrite(g_flightQueue, &ptr);
+        g_writeBuf ^= 1;  // swap buffers
+
+        LOG_V("Main", "Flight data queued for display task");
+    }
+
+    // No delay() — loop naturally yields via fetch interval timer
+}
+
+#endif // PIO_UNIT_TESTING
