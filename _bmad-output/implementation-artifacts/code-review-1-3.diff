@@ -0,0 +1,36 @@
+#pragma once
+
+#include <stdint.h>
+#include <vector>
+#include "interfaces/BaseDisplay.h"
+
+class FastLED_NeoMatrix;
+struct CRGB;
+
+class NeoMatrixDisplay : public BaseDisplay
+{
+public:
+    NeoMatrixDisplay();
+    ~NeoMatrixDisplay() override;
+
+    bool initialize() override;
+    void clear() override;
+    void displayFlights(const std::vector<FlightInfo> &flights) override;
+    void displayMessage(const String &message);
+    void showLoading();
+
+    // Story 1.3: task-safe display task methods
+    void updateBrightness(uint8_t brightness);
+    void renderFlight(const FlightInfo &flight);
+
+private:
+    FastLED_NeoMatrix *_matrix = nullptr;
+    CRGB *_leds = nullptr;
+
+    uint16_t _matrixWidth = 0;
+    uint16_t _matrixHeight = 0;
+    uint32_t _numPixels = 0;
+
+    void drawTextLine(int16_t x, int16_t y, const String &text, uint16_t color);
+    String makeFlightLine(const FlightInfo &f);
+    String truncateToColumns(const String &text, int maxColumns);
+    void displaySingleFlightCard(const FlightInfo &f);
+    void displayLoadingScreen();
+};
diff --git a/firmware/adapters/NeoMatrixDisplay.cpp b/firmware/adapters/NeoMatrixDisplay.cpp
new file mode 100644
index 0000000..6ea0988
--- /dev/null
+++ b/firmware/adapters/NeoMatrixDisplay.cpp
@@ -0,0 +1,103 @@
+/*
+Purpose: Render flight info on a WS2812B NeoPixel matrix via FastLED_NeoMatrix.
+Responsibilities:
+- Initialize LED matrix based on HardwareConfiguration and user display settings.
+- Render a bordered, three-line flight “card” and a minimal loading screen.
+- Cycle through multiple flights at a configurable interval.
+Inputs: FlightInfo list; ConfigManager for colors/brightness/timing/hardware.
+Outputs: Visual output to LED matrix using FastLED.
+*/
+#include "adapters/NeoMatrixDisplay.h"
+
+#include <Adafruit_GFX.h>
+#include <FastLED_NeoMatrix.h>
+#include <FastLED.h>
+#include "utils/Log.h"
+#include "core/ConfigManager.h"
+
+NeoMatrixDisplay::NeoMatrixDisplay() {}
+
+NeoMatrixDisplay::~NeoMatrixDisplay()
+{
+    if (_leds)
+    {
+        delete[] _leds;
+        _leds = nullptr;
+    }
+    if (_matrix)
+    {
+        delete _matrix;
+        _matrix = nullptr;
+    }
+}
+
+bool NeoMatrixDisplay::initialize()
+{
+    HardwareConfig hw = ConfigManager::getHardware();
+    DisplayConfig disp = ConfigManager::getDisplay();
+
+    _matrixWidth = hw.tile_pixels * hw.tiles_x;
+    _matrixHeight = hw.tile_pixels * hw.tiles_y;
+    _numPixels = (uint32_t)_matrixWidth * (uint32_t)_matrixHeight;
+
+    _leds = new CRGB[_numPixels];
+
+    _matrix = new FastLED_NeoMatrix(
+        _leds,
+        hw.tile_pixels,
+        hw.tile_pixels,
+        hw.tiles_x,
+        hw.tiles_y,
+        NEO_MATRIX_BOTTOM + NEO_MATRIX_RIGHT +
+            NEO_MATRIX_COLUMNS + NEO_MATRIX_ZIGZAG +
+            NEO_TILE_TOP + NEO_TILE_RIGHT + NEO_TILE_COLUMNS + NEO_TILE_ZIGZAG);
+
+    // Story 1.2: display_pin handled via runtime-to-template mapping
+    configureStripForPin(hw.display_pin, _leds, _numPixels);
+    _matrix->setTextWrap(false);
+    _matrix->setTextSize(1);
+    _matrix->setBrightness(disp.brightness);
+    clear();
+    return true;
+}
+
+void NeoMatrixDisplay::updateBrightness(uint8_t brightness)
+{
+    if (_matrix)
+    {
+        _matrix->setBrightness(brightness);
+        FastLED.show();
+    }
+}
+
+void NeoMatrixDisplay::renderFlight(const FlightInfo &flight)
+{
+    if (_matrix == nullptr)
+        return;
+
+    _matrix->fillScreen(0);
+    displaySingleFlightCard(flight);
+    FastLED.show();
+}
+
+void NeoMatrixDisplay::clear()
+{
+    if (_matrix)
+    {
+        _matrix->fillScreen(0);
+        FastLED.show();
+    }
+}
+
+void NeoMatrixDisplay::displayFlights(const std::vector<FlightInfo> &flights)
+{
+    // Retained for BaseDisplay compatibility; display task uses renderFlight()
+    if (!flights.empty())
+    {
+        renderFlight(flights[0]);
+    }
+    else
+    {
+        showLoading();
+    }
+}
+
+void NeoMatrixDisplay::showLoading()
+{
+    displayLoadingScreen();
+}
