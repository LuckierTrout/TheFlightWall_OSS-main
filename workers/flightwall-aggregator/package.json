    "typecheck": "npm run typegen && tsc --noEmit",
    "typegen": "wrangler types"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3",
    "wrangler": "^4.45.0"
  }
}
