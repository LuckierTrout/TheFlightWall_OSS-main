PORT=8080
HOST=0.0.0.0
PUBLIC_BASE_URL=http://flightwall-pi.local:8080
DATABASE_PATH=./data/flightwall-pi.db
ASSET_DIR=./data/assets

# Set these in /etc/flightwall-pi.env if the Pi should fetch live aircraft
# from the Cloudflare Worker.
AGGREGATOR_URL=
AGGREGATOR_TOKEN=
CONTROLLER_POLL_INTERVAL_MS=15000
AUTO_PUBLISH_ENABLED=true
AUTO_PUBLISH_INTERVAL_MS=30000
